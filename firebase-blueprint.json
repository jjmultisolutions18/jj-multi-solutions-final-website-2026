{
  "entities": {
    "Enquiry": {
      "title": "Enquiry",
      "description": "General contact form submission",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "businessName": { "type": "string" },
        "service": { "type": "string" },
        "message": { "type": "string" },
        "consent": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message", "consent"]
    },
    "QuoteRequest": {
      "title": "Quote Request",
      "description": "Detailed request for a service quote",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "businessName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "serviceRequired": { "type": "string" },
        "budgetRange": { "type": "string" },
        "timeline": { "type": "string" },
        "projectDescription": { "type": "string" },
        "fileUrl": { "type": "string" },
        "preferredContact": { "type": "string" },
        "consent": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "serviceRequired", "projectDescription", "consent"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "Article for the blog section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "category": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "slug", "category", "content"]
    },
    "Event": {
      "title": "Event",
      "description": "Upcoming or past event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "venue": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["upcoming", "past", "ongoing"] },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "date", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "Gallery project or product",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Completed", "In Progress", "Concept"] },
        "imageUrl": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["title", "category", "status"]
    },
    "StoreProduct": {
      "title": "StoreProduct",
      "description": "Digital product or business solution offered in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "shortDescription": { "type": "string" },
        "features": { "type": "array" },
        "monthlyPrice": { "type": "number" },
        "annualPrice": { "type": "number" },
        "imageUrl": { "type": "string" },
        "isActive": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "shortDescription", "monthlyPrice", "annualPrice", "isActive", "isFeatured"]
    },
    "StoreQuotationRequest": {
      "title": "StoreQuotationRequest",
      "description": "In-Store single or multi-product quotation request with enquiry basket",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "businessName": { "type": "string" },
        "message": { "type": "string" },
        "items": { "type": "array" },
        "totalMonthlyAmount": { "type": "number" },
        "totalAnnualAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed", "invoice_sent"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" }
      },
      "required": ["fullName", "email", "phone", "businessName", "items", "totalMonthlyAmount", "totalAnnualAmount", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Billing statement for client products/subscriptions",
      "type": "object",
      "properties": {
        "quoteRequestId": { "type": "string" },
        "customerUid": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "date": { "type": "string" },
        "dueDate": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "unpaid", "overdue"] },
        "paymentGateway": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["quoteRequestId", "customerUid", "invoiceNumber", "date", "dueDate", "items", "totalAmount", "status"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Active subscriptional services for client business",
      "type": "object",
      "properties": {
        "customerUid": { "type": "string" },
        "productName": { "type": "string" },
        "productId": { "type": "string" },
        "billingCycle": { "type": "string", "enum": ["monthly", "annual"] },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "cancelled", "paused"] },
        "startDate": { "type": "string" },
        "nextBillingDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerUid", "productName", "productId", "billingCycle", "price", "status", "startDate", "nextBillingDate"]
    },
    "SupportRequest": {
      "title": "SupportRequest",
      "description": "Customer helpdesk ticket",
      "type": "object",
      "properties": {
        "customerUid": { "type": "string" },
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "category": { "type": "string", "enum": ["Technical", "Billing", "General"] },
        "status": { "type": "string", "enum": ["open", "in_progress", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "adminResponse": { "type": "string" }
      },
      "required": ["customerUid", "customerName", "customerEmail", "subject", "message", "category", "status"]
    }
  },
  "firestore": {
    "enquiries/{enquiryId}": {
      "schema": "Enquiry",
      "description": "General contact enquiries"
    },
    "quoteRequests/{quoteId}": {
      "schema": "QuoteRequest",
      "description": "Service quote requests"
    },
    "blogs/{blogId}": {
      "schema": "BlogPost",
      "description": "Blog articles"
    },
    "events/{eventId}": {
      "schema": "Event",
      "description": "News and events"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Company projects and gallery items"
    },
    "storeProducts/{productId}": {
      "schema": "StoreProduct",
      "description": "Digital services products catalog"
    },
    "storeQuotationRequests/{quoteId}": {
      "schema": "StoreQuotationRequest",
      "description": "Store single or multi quotation basket requests"
    },
    "invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices billing details"
    },
    "subscriptions/{subscriptionId}": {
      "schema": "Subscription",
      "description": "Active recurring software-solutions subscriptions"
    },
    "supportRequests/{supportId}": {
      "schema": "SupportRequest",
      "description": "Customer dashboard helpdesk tickets"
    }
  }
}
